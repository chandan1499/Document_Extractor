# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# LLM Configuration
LLM_PROVIDER=groq
# Available Groq models (update based on your account access):
# - mixtral-8x7b-32768 (recommended - most available)
# - llama2-70b-4096
# - gemma-7b-it
# - llama-3-70b-versatile
# - llama-3-8b-instant
EXTRACT_MODEL=mixtral-8x7b-32768
CLASSIFY_MODEL=mixtral-8x7b-32768

# Data (Supabase Postgres)
DATABASE_URL=postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Legacy — only used by db:import-json migration script
DATA_DIR=./data
